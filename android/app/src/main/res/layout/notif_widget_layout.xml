<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="10dp"
    android:background="#CC1E1E2E">

    <TextView
        android:id="@+id/widget_title"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Notifications"
        android:textColor="#CDD6F4"
        android:textSize="15sp"
        android:textStyle="bold"
        android:paddingBottom="6dp"/>

    <LinearLayout
        android:id="@+id/row1"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingBottom="4dp"
        android:visibility="gone">
        <ImageView
            android:id="@+id/icon1"
            android:layout_width="28dp"
            android:layout_height="28dp"
            android:scaleType="fitCenter"
            android:layout_marginEnd="6dp"/>
        <TextView
            android:id="@+id/notif1"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:textColor="#CDD6F4"
            android:textSize="13sp"
            android:maxLines="3"/>
    </LinearLayout>

    <View android:id="@+id/div1" android:layout_width="match_parent" android:layout_height="1dp" android:background="#313244" android:visibility="gone"/>

    <LinearLayout
        android:id="@+id/row2"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingTop="4dp"
        android:paddingBottom="4dp"
        android:visibility="gone">
        <ImageView
            android:id="@+id/icon2"
            android:layout_width="28dp"
            android:layout_height="28dp"
            android:scaleType="fitCenter"
            android:layout_marginEnd="6dp"/>
        <TextView
            android:id="@+id/notif2"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:textColor="#CDD6F4"
            android:textSize="13sp"
            android:maxLines="3"/>
    </LinearLayout>

    <View android:id="@+id/div2" android:layout_width="match_parent" android:layout_height="1dp" android:background="#313244" android:visibility="gone"/>

    <LinearLayout
        android:id="@+id/row3"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingTop="4dp"
        android:paddingBottom="4dp"
        android:visibility="gone">
        <ImageView
            android:id="@+id/icon3"
            android:layout_width="28dp"
            android:layout_height="28dp"
            android:scaleType="fitCenter"
            android:layout_marginEnd="6dp"/>
        <TextView
            android:id="@+id/notif3"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:textColor="#CDD6F4"
            android:textSize="13sp"
            android:maxLines="3"/>
    </LinearLayout>

    <View android:id="@+id/div3" android:layout_width="match_parent" android:layout_height="1dp" android:background="#313244" android:visibility="gone"/>

    <LinearLayout
        android:id="@+id/row4"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingTop="4dp"
        android:paddingBottom="4dp"
        android:visibility="gone">
        <ImageView
            android:id="@+id/icon4"
            android:layout_width="28dp"
            android:layout_height="28dp"
            android:scaleType="fitCenter"
            android:layout_marginEnd="6dp"/>
        <TextView
            android:id="@+id/notif4"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:textColor="#CDD6F4"
            android:textSize="13sp"
            android:maxLines="3"/>
    </LinearLayout>

    <View android:id="@+id/div4" android:layout_width="match_parent" android:layout_height="1dp" android:background="#313244" android:visibility="gone"/>

    <LinearLayout
        android:id="@+id/row5"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingTop="4dp"
        android:visibility="gone">
        <ImageView
            android:id="@+id/icon5"
            android:layout_width="28dp"
            android:layout_height="28dp"
            android:scaleType="fitCenter"
            android:layout_marginEnd="6dp"/>
        <TextView
            android:id="@+id/notif5"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:textColor="#CDD6F4"
            android:textSize="13sp"
            android:maxLines="3"/>
    </LinearLayout>

</LinearLayout>
