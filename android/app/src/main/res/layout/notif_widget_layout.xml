<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="10dp"
    android:background="#CC1E1E2E">

    <TextView
        android:id="@+id/widget_title"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Notifications"
        android:textColor="#CDD6F4"
        android:textSize="14sp"
        android:textStyle="bold"
        android:paddingBottom="6dp"/>

    <TextView
        android:id="@+id/notif1"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textColor="#A6ADC8"
        android:textSize="12sp"
        android:paddingBottom="4dp"
        android:maxLines="3"/>

    <View
        android:id="@+id/div1"
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#313244"
        android:visibility="gone"/>

    <TextView
        android:id="@+id/notif2"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textColor="#A6ADC8"
        android:textSize="12sp"
        android:paddingBottom="4dp"
        android:maxLines="3"/>

    <View
        android:id="@+id/div2"
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#313244"
        android:visibility="gone"/>

    <TextView
        android:id="@+id/notif3"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textColor="#A6ADC8"
        android:textSize="12sp"
        android:paddingBottom="4dp"
        android:maxLines="3"/>

    <View
        android:id="@+id/div3"
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#313244"
        android:visibility="gone"/>

    <TextView
        android:id="@+id/notif4"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textColor="#A6ADC8"
        android:textSize="12sp"
        android:paddingBottom="4dp"
        android:maxLines="3"/>

    <View
        android:id="@+id/div4"
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#313244"
        android:visibility="gone"/>

    <TextView
        android:id="@+id/notif5"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textColor="#A6ADC8"
        android:textSize="12sp"
        android:maxLines="3"/>

</LinearLayout>
